      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@ / %2$@ present"
          }
        }
      }
    },
    "%@ is marked Absent. Please ask a teacher to sign you in.": {},
    "%@ sessions": {
      "comment": "A label displaying the number of sessions in a student's attendance history. The argument is the count of sessions in the student's attendance history.",
      "isCommentAutoGenerated": true
    },
    "%@ student%@ have no status yet. Mark them all as Absent?": {
      "comment": "A message in a confirmation dialog that asks the user to mark all students with no status as absent.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@ student%2$@ have no status yet. Mark them all as Absent?"
          }
        }
      }
    },
    "%@ was dismissed at %@.": {
      "comment": "A sentence that describes a dismissal with a date. The first argument is the name of the child. The second argument is the formatted date of dismissal.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@ was dismissed at %2$@."
          }
        }
      }
    },
    "%@ was dismissed today.": {
      "comment": "A message that appears when a child's dismissal is set to today.",
      "isCommentAutoGenerated": true
    },
    "%@%%": {
      "comment": "A label that displays the attendance rate as a percentage. The argument is the attendance rate as a percentage.",
      "isCommentAutoGenerated": true
    },
    "ADMIN": {},
    "Admin Access": {},
    "Allow camera access for TAVAttendance in Settings to scan student QR codes.": {
      "comment": "A description of the camera access alert.",
      "isCommentAutoGenerated": true
    },
    "Anonymise keeps anonymous attendance stats; Erase removes everything. Both are irreversible.": {},
    "Anyone enrolled in %@ on this iPad can unlock admin mode. Enable only if this device's %@ is staff-only. The PIN always remains available.": {
      "comment": "A description of the biometric unlock option. The argument is the name of the biometric method (e.g., Touch ID or Face ID).",
      "isCommentAutoGenerated": true,
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Anyone enrolled in %1$@ on this iPad can unlock admin mode. Enable only if this device's %2$@ is staff-only. The PIN always remains available."
          }
        }
      }
    },
    "Apply “%@” to %@ selected student%@?": {
      "localizations": {
        "en": {
          "stringUnit": {
