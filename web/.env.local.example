NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-only. Required for invites and cross-system Storage cleanup. Never use
# NEXT_PUBLIC_ for this value and never commit the populated .env.local file.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Absolute production origin used in invite redirect links.
SITE_URL=http://localhost:3000

# Superadmin authority is an immutable user UUID stored in the database by
# migration 038; there is intentionally no email-based application override.
