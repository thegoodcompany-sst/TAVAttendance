#!/bin/sh
# DEVOPS-03: refuse to commit files containing Supabase secret keys.
# Enable once per clone:  git config core.hooksPath .githooks

# Scan staged content (added/changed lines) for secret assignments.
matches=$(git diff --cached -U0 | grep -nE '^\+.*SUPABASE_(ANON|SERVICE_ROLE)_KEY=.+' )

if [ -n "$matches" ]; then
  echo "✖ pre-commit blocked: a staged change assigns a Supabase key."
  echo "  Keep keys in gitignored config (Config.xcconfig / secrets.properties / .env.local)."
  echo "$matches"
  exit 1
fi

# Also catch a raw JWT literal (e.g. a Swift string `supabaseKey: "eyJ..."`) —
# the header.payload shape of any JWT, regardless of variable name.
jwt_matches=$(git diff --cached -U0 | grep -nE '^\+.*eyJ[A-Za-z0-9_-]{20,}\.[A-Za-z0-9_-]{20,}')

if [ -n "$jwt_matches" ]; then
  echo "✖ pre-commit blocked: a staged change contains a raw JWT-shaped secret."
  echo "  Keep keys in gitignored config (Config.xcconfig / secrets.properties / .env.local)."
  echo "$jwt_matches"
  exit 1
fi

exit 0
